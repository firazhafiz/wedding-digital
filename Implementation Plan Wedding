## 3. Database Schema (Supabase)

```sql
-- Tabel tamu undangan
CREATE TABLE guests (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  name TEXT NOT NULL,              -- Nama lengkap tamu
  slug TEXT NOT NULL UNIQUE,       -- URL slug: "budi-santoso"
  max_pax INT DEFAULT 2,          -- Maksimal tamu yang boleh dibawa
  rsvp_status TEXT DEFAULT 'pending', -- 'pending' | 'attending' | 'not_attending'
  rsvp_pax INT DEFAULT 0,         -- Jumlah yang hadir
  rsvp_message TEXT,              -- Pesan dari tamu saat RSVP (opsional)
  checked_in BOOLEAN DEFAULT FALSE,
  checked_in_at TIMESTAMPTZ,
  qr_token TEXT NOT NULL UNIQUE,  -- Token unik untuk QR code
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Buku tamu / ucapan
CREATE TABLE guestbook (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  guest_id UUID REFERENCES guests(id) ON DELETE CASCADE,
  guest_name TEXT NOT NULL,        -- Nama yang ditampilkan
  message TEXT NOT NULL,
  status TEXT DEFAULT 'pending',   -- 'pending' | 'approved' | 'rejected'
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Digital angpao / konfirmasi transfer
CREATE TABLE gifts (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  guest_id UUID REFERENCES guests(id) ON DELETE SET NULL,
  sender_name TEXT NOT NULL,
  bank_name TEXT,
  amount NUMERIC,
  proof_url TEXT,                  -- URL bukti transfer (Supabase Storage)
  notes TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Event info (single row, editable dari admin)
CREATE TABLE event_info (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  groom_name TEXT NOT NULL,
  groom_father TEXT,
  groom_mother TEXT,
  groom_photo_url TEXT,
  groom_instagram TEXT,
  bride_name TEXT NOT NULL,
  bride_father TEXT,
  bride_mother TEXT,
  bride_photo_url TEXT,
  bride_instagram TEXT,
  akad_date TIMESTAMPTZ,
  akad_location TEXT,
  akad_maps_url TEXT,
  resepsi_date TIMESTAMPTZ,
  resepsi_location TEXT,
  resepsi_maps_url TEXT,
  hero_photo_url TEXT,
  audio_url TEXT,
  bank_name TEXT,
  bank_account_number TEXT,
  bank_account_holder TEXT,
  qris_image_url TEXT,
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Storyline items
CREATE TABLE storyline (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  year TEXT NOT NULL,
  title TEXT NOT NULL,
  description TEXT,
  photo_url TEXT,
  sort_order INT DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Gallery photos
CREATE TABLE gallery (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  photo_url TEXT NOT NULL,
  caption TEXT,
  sort_order INT DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW()
);
```

> [!IMPORTANT]
> User perlu membuat project Supabase terlebih dahulu dan menyediakan `NEXT_PUBLIC_SUPABASE_URL` dan `NEXT_PUBLIC_SUPABASE_ANON_KEY`. Tabel di atas akan di-setup melalui Supabase SQL Editor.

